{
  "name": "ai-canvas",
  "private": true,
  "version": "1.0.2",
  "main": "electron/main.js",
  "author": "WFS老师",
  "description": "AI 数学可视化工具 - 小学数学折线统计图教学神器",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "vue": "^3.2.0",
    "pinia": "^2.0.0",
    "echarts": "^5.4.0",
    "vue-echarts": "^6.0.0",
    "gsap": "^3.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^2.0.0",
    "vite": "^2.9.0",
    "electron": "^22.0.0",
    "electron-builder": "^23.0.0"
  },
  "build": {
    "appId": "com.ai-canvas.app",
    "productName": "AI数学可视化工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI数学可视化工具"
    }
  }
}
